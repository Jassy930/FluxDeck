    "dialog.delete_gateway.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Delete `%1$@` permanently. This does not require deleting its Provider first. If this Gateway is running, the system will stop it before deletion."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将永久删除 `%1$@`。无需先删除其 Provider；如果该 Gateway 正在运行，系统会先停止它再删除。"
          }
        }
      }
    },
    "dialog.delete_gateway.title" : {
      "extractionState" : "manual",
